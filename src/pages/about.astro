---
import Base from "../layouts/Base.astro";
---
<Base title="About" description="Nate Jones is a fine art photographer based in Durham, North Carolina.">
  <section class="page prose">
    <h1>About</h1>

    <p class="lede">
      Nate Jones is a fine art photographer based in Durham, North Carolina.
      He shoots primarily on Kodak Ektachrome and TMax film.
    </p>

    <p class="lede">
      His work centers on Americana and landscape: weathered storefronts and
      neon, classical and brutalist architecture, open country, the quiet hours.
    </p>

    <p class="lede">
      For prints, licensing, or just to say hello, the
      <a href="/contact/">contact page</a> goes straight to his inbox.
    </p>
  </section>
</Base>
